{
  "name": "react-redux-firebase",
  "version": "4.0.0",
  "description": "Redux integration for Firebase. Comes with a Higher Order Components for use with React.",
  "main": "lib/index.js",
  "module": "es/index.js",
  "typings": "./index.d.ts",
  "scripts": {
    "clean": "rimraf es lib coverage",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "build:commonjs": "cross-env BABEL_ENV=commonjs babel src --out-dir lib --source-maps",
    "build:es": "cross-env BABEL_ENV=es babel src --out-dir es --source-maps",
    "build": "npm run build:commonjs && npm run build:es",
    "watch": "npm run build:commonjs -- --watch",
    "watch:es": "npm run build:es -- --watch",
    "prepare": "husky",
    "prepack": "npm run clean && npm run build"
  },
  "license": "MIT",
  "homepage": "http://react-redux-firebase.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prescottprue/react-redux-firebase.git"
  },
  "bugs": {
    "url": "https://github.com/prescottprue/react-redux-firebase/issues"
  },
  "author": {
    "name": "Prescott Prue",
    "url": "https://github.com/prescottprue"
  },
  "keywords": [
    "firebase",
    "redux",
    "react",
    "react-redux",
    "redux-firebase",
    "react",
    "babel",
    "hoc",
    "hooks",
    "redux-react-firebase"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "hoist-non-react-statics": "^3.3.2",
    "lodash": "^4.17.21",
    "prop-types": "^15.7.2"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@vitest/coverage-v8": "^4.1.8",
    "@wojtekmaj/enzyme-adapter-react-17": "^0.6.5",
    "babel-plugin-add-module-exports": "^1.0.4",
    "babel-plugin-lodash": "^3.3.4",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.1",
    "cross-env": "^10.1.0",
    "enzyme": "^3.10.0",
    "firebase": "7.14.6",
    "firebase-server": "^1.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "redux": "4.0.0",
    "redux-firestore": "0.5.7",
    "rimraf": "^6.1.3",
    "sinon": "^9.0.1",
    "sinon-chai": "^3.5.0",
    "vitest": "^4.1.8",
    "ws": "^3.2.0",
    "xmlhttprequest": "^1.8.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "collective": {
    "type": "opencollective",
    "url": "https://opencollective.com/react-redux-firebase",
    "logo": "https://opencollective.com/opencollective/logo.txt"
  },
  "lint-staged": {
    "*.{js,jsx,json}": [
      "biome check --no-errors-on-unmatched --write"
    ]
  }
}
