{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rangeStrategy": "replace",
  "extends": [
    "github>prescottprue/renovate-config:library",
    "customManagers:biomeVersions",
    "helpers:pinGitHubActionDigests"
  ],
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "chai 5+ is ESM-only and couples chai-as-promised/sinon-chai majors; redux 4 / redux-firestore pins match the v3-era test store. Update manually.",
      "matchPackageNames": [
        "chai",
        "chai-as-promised",
        "sinon-chai",
        "redux",
        "redux-firestore"
      ],
      "enabled": false
    },
    {
      "description": "Examples are stale v3-era apps; update manually",
      "matchFileNames": ["examples/**"],
      "enabled": false
    }
  ]
}
