{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rangeStrategy": "replace",
  "extends": [
    "github>prescottprue/renovate-config:library",
    "customManagers:biomeVersions",
    "helpers:pinGitHubActionDigests"
  ],
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "redux-firestore 2.x peer-requires firebase ^9 (we test against firebase 12); update manually if a compatible release lands",
      "matchPackageNames": ["redux-firestore"],
      "enabled": false
    },
    {
      "description": "Examples are stale v3-era apps; update manually",
      "matchFileNames": ["examples/**"],
      "enabled": false
    }
  ]
}
